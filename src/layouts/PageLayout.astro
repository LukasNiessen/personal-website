---
import "@styles/global.css";
import BaseHead from "@components/BaseHead.astro";
import Header from "@components/Header.astro";
import Footer from "@components/Footer.astro";
import Drawer from "@components/Drawer.astro";
import StageBanner from "@components/StageBanner.astro";
const { title, description } = Astro.props;
import { SITE } from "@consts";
const isProduction = import.meta.env.IS_PRODUCTION === "true";
---

<!doctype html>
<html lang="en" data-env={isProduction ? "production" : "stage"}>
  <head>
    <BaseHead title={`${title} | ${SITE.TITLE}`} description={description} />
  </head>
  <body>
    <StageBanner />
    <Header />
    <Drawer />
    <main>
      <slot />
    </main>
    <Footer />
  </body>
</html>
